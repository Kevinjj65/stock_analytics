# =============================================================
# STOCK MARKET ANALYTICS PLATFORM — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your real values.
# NEVER commit the .env file to git — it is in .gitignore.
# =============================================================


# --- SUPABASE ---
# Find all three values in your Supabase dashboard → Project Settings → API / Database

# Your Supabase project URL (e.g. https://abcdefghijkl.supabase.co)
SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anon public key (safe for client-side use) OR service_role key (server-side only)
# Use the service_role key here since this is a backend server — it bypasses Row Level Security
SUPABASE_KEY=your-supabase-anon-or-service-role-key

# Direct PostgreSQL connection string for SQLAlchemy (asyncpg driver)
# Find: Supabase Dashboard → Project Settings → Database → Connection string → URI
# IMPORTANT: Replace 'postgresql://' with 'postgresql+asyncpg://' for async SQLAlchemy
# Also replace [YOUR-PASSWORD] with your actual database password
SUPABASE_DB_URL=postgresql+asyncpg://postgres:[YOUR-PASSWORD]@db.your-project-id.supabase.co:5432/postgres


# --- JWT AUTHENTICATION ---
# Used to sign and verify user login tokens

# A long random secret string — generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production

# Signing algorithm — HS256 (HMAC + SHA-256) is the standard for symmetric JWT signing
JWT_ALGORITHM=HS256

# How many minutes a login token stays valid before the user must log in again
JWT_EXPIRE_MINUTES=30


# --- EXTERNAL APIs ---

# NewsAPI key for fetching financial news headlines (used by sentiment_service.py)
# Free tier: 100 requests/day — sign up at https://newsapi.org
NEWS_API_KEY=your-newsapi-key

# Groq API key for LLM inference in the RAG Q&A feature (used by rag_service.py)
# Free tier — sign up at https://console.groq.com
GROQ_API_KEY=your-groq-api-key


# --- APPLICATION ---

# Runtime environment — controls logging verbosity and CORS settings
# Valid values: development | staging | production
ENVIRONMENT=development
